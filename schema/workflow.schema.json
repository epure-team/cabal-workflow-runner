{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://epure-team.github.io/cabal-workflow-runner/workflow.schema.json",
  "title": "cabal-workflow-runner workflow",
  "description": "A declarative workflow for cabal-workflow-runner: a name plus a list of steps. This schema describes exactly the JSON that Workflow_json parses. Every workflow / step / governor / expr object is closed: unknown keys are rejected, except keys prefixed with _ (ignored metadata, e.g. the _doc convention). Schema constrains shape at generation; Lint catches semantics/safety pre-run; Validate is the run gate.",
  "type": "object",
  "required": [ "name", "steps" ],
  "properties": {
    "name": { "type": "string" },
    "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
    "version": { "type": "string" }
  },
  "patternProperties": { "^_": {} },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "description": "A workflow step, discriminated by the \"kind\" key.",
      "oneOf": [
        {
          "type": "object",
          "required": [ "kind", "id", "prompt" ],
          "properties": {
            "kind": { "const": "agent" },
            "id": { "type": "string" },
            "prompt": { "type": "string" },
            "read_only": { "type": "boolean" },
            "output_schema": { "$ref": "#/$defs/output_schema" },
            "on_failure": { "enum": [ "abort", "continue" ] },
            "protocol": { "type": "string" },
            "brief": { "type": "string" },
            "agent_type": { "type": "string" }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "id", "when" ],
          "properties": {
            "kind": { "const": "gate" },
            "id": { "type": "string" },
            "when": { "$ref": "#/$defs/expr" }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "when", "then", "else" ],
          "properties": {
            "kind": { "const": "branch" },
            "when": { "$ref": "#/$defs/expr" },
            "then": { "type": "array", "items": { "$ref": "#/$defs/step" } },
            "else": { "type": "array", "items": { "$ref": "#/$defs/step" } }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "governors", "body" ],
          "properties": {
            "kind": { "const": "loop" },
            "until": { "$ref": "#/$defs/expr" },
            "governors": {
              "type": "array",
              "items": { "$ref": "#/$defs/governor" },
              "minItems": 1
            },
            "body": { "type": "array", "items": { "$ref": "#/$defs/step" } }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "id", "cmd", "working_dir" ],
          "properties": {
            "kind": { "const": "run" },
            "id": { "type": "string" },
            "cmd": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "working_dir": {
              "type": "string",
              "pattern": "^(?!/)(?!(.*/)?\\.\\.(/|$)).+$"
            },
            "timeout_ms": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4611686018427387903
            },
            "observe": { "type": "array", "items": { "type": "string" } }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "id" ],
          "properties": {
            "kind": { "const": "commit" },
            "id": { "type": "string" }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "branches" ],
          "properties": {
            "kind": { "const": "parallel" },
            "branches": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "array",
                "items": { "$ref": "#/$defs/step" }
              }
            }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "over", "steps" ],
          "properties": {
            "kind": { "const": "foreach" },
            "over": { "type": "string" },
            "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "id", "commands" ],
          "properties": {
            "kind": { "const": "shell" },
            "id": { "type": "string" },
            "commands": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "on_failure": { "enum": [ "abort", "continue" ] }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "kind", "id", "build", "check", "zero_admits", "tier", "output"
          ],
          "properties": {
            "kind": { "const": "evidence" },
            "id": { "type": "string" },
            "build": { "type": "string" },
            "check": { "type": "string" },
            "zero_admits": { "type": "string" },
            "tier": { "type": "string" },
            "output": { "type": "string" }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        }
      ]
    },
    "expr": {
      "description": "A total-predicate-DSL expression: a single-operator object. See Workflow_json's expr encoding.",
      "oneOf": [
        {
          "type": "object",
          "required": [ "path" ],
          "properties": { "path": { "type": "string" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "exists" ],
          "properties": { "exists": { "type": "string" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "lit" ],
          "properties": { "lit": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "eq" ],
          "properties": {
            "eq": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "ne" ],
          "properties": {
            "ne": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "lt" ],
          "properties": {
            "lt": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "le" ],
          "properties": {
            "le": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "gt" ],
          "properties": {
            "gt": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "ge" ],
          "properties": {
            "ge": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "in" ],
          "properties": {
            "in": {
              "type": "array",
              "items": { "$ref": "#/$defs/expr" },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "and" ],
          "properties": {
            "and": { "type": "array", "items": { "$ref": "#/$defs/expr" } }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "or" ],
          "properties": {
            "or": { "type": "array", "items": { "$ref": "#/$defs/expr" } }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "not" ],
          "properties": { "not": { "$ref": "#/$defs/expr" } },
          "additionalProperties": false
        }
      ]
    },
    "governor": {
      "description": "A loop governor (termination guarantee).",
      "oneOf": [
        {
          "type": "object",
          "required": [ "kind", "n" ],
          "properties": {
            "kind": { "const": "max_iters" },
            "n": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4611686018427387903
            }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind" ],
          "properties": { "kind": { "const": "budget" } },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [ "kind", "window", "progress" ],
          "properties": {
            "kind": { "const": "fixpoint" },
            "window": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4611686018427387903
            },
            "progress": { "$ref": "#/$defs/expr" }
          },
          "patternProperties": { "^_": {} },
          "additionalProperties": false
        }
      ]
    },
    "output_schema": {
      "description": "Maps each required field name to a type tag (\"string\"|\"int\"|\"number\"|\"bool\"|\"any\") or an {\"enum\":[string,...]} object.",
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "enum": [ "string", "int", "number", "bool", "any" ]
          },
          {
            "type": "object",
            "required": [ "enum" ],
            "properties": {
              "enum": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        ]
      }
    }
  }
}
