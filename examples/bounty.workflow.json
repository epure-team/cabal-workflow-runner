{
  "name": "bounty-pipeline",
  "steps": [
    { "kind": "agent", "id": "recon",
      "prompt": "Survey the target and enumerate candidate findings.",
      "read_only": true,
      "output_schema": { "candidates": "int" } },

    { "kind": "loop",
      "until": { "eq": [ { "path": "outputs.deep-dive.exhausted" }, { "lit": true } ] },
      "governors": [
        { "kind": "max_iters", "n": 5 },
        { "kind": "budget" },
        { "kind": "fixpoint", "window": 2,
          "progress": { "path": "outputs.deep-dive.progressed" } }
      ],
      "body": [
        { "kind": "agent", "id": "deep-dive",
          "prompt": "Investigate the next candidate finding in depth.",
          "read_only": true,
          "output_schema": { "exhausted": "bool", "progressed": "bool" } },
        { "kind": "agent", "id": "draft-poc",
          "prompt": "Draft a proof-of-concept for the current candidate.",
          "read_only": false,
          "output_schema": { "ok": "bool" } }
      ] },

    { "kind": "agent", "id": "writeup",
      "prompt": "Write the report for the strongest finding.",
      "read_only": false,
      "output_schema": { "severity": { "enum": ["low", "medium", "high", "critical"] } } },

    { "kind": "agent", "id": "final-review",
      "prompt": "Independent reviewer signs off on the finding.",
      "read_only": true,
      "output_schema": { "verdict": { "enum": ["approved", "rejected"] } } },

    { "kind": "gate", "id": "g-validated",
      "when": { "exists": "outputs.writeup.severity" } },
    { "kind": "gate", "id": "g-observed",
      "when": { "exists": "outputs.draft-poc.ok" } },
    { "kind": "gate", "id": "g-independent",
      "when": { "eq": [ { "path": "outputs.final-review.verdict" }, { "lit": "approved" } ] } },

    { "kind": "branch",
      "when": { "in": [ { "path": "outputs.writeup.severity" }, { "lit": ["high", "critical"] } ] },
      "then": [
        { "kind": "commit", "id": "submit-bounty" }
      ],
      "else": [
        { "kind": "agent", "id": "abort-note",
          "prompt": "Record why the finding did not clear triage.",
          "read_only": true }
      ] }
  ]
}
